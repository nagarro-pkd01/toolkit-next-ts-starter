{
  "name": "toolkit-next-ts-starter",
  "version": "0.0.2",
  "private": false,
  "description": "Enterprise-ready Next.js + strict TypeScript starter with projen, ESLint + Prettier, release automation, and config-driven multi-client architecture.",
  "keywords": [
    "nextjs",
    "starter",
    "template",
    "enterprise",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "toolkit-next-ts-starter": "scripts/create-starter.mjs"
  },
  "files": [
    ".claude/skills.md",
    ".cursor/skills",
    ".editorconfig",
    ".env.example",
    ".github",
    "lefthook.yml",
    ".projen",
    ".projenrc.js",
    ".releaserc.json",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "eslint.config.mjs",
    "prettier.config.cjs",
    ".prettierignore",
    "commitlint.config.cjs",
    "docs",
    "next-env.d.ts",
    "next.config.ts",
    "public",
    "scripts/create-starter.mjs",
    "src",
    "tsconfig.json",
    "vitest.config.mts",
    "vitest.setup.ts"
  ],
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit --pretty",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "lint:commits": "commitlint --last",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "analyze:bundle": "node ./scripts/reportBundleSize.mjs",
    "analyze:bundle:build": "node ./scripts/reportBundleSize.mjs --build",
    "analyze:bundle:ci": "node ./scripts/reportBundleSize.mjs --ci",
    "prepare": "lefthook install",
    "projen": "projen",
    "create:starter": "node ./scripts/create-starter.mjs",
    "prepublishOnly": "npm run validate",
    "lhci": "npx -y @lhci/cli autorun --config=.lighthouserc.js --upload.target=temporary-public-storage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "security:scan": "trivy fs .",
    "security:json": "trivy fs --format json --output reports/trivy-report.json .",
    "security:sarif": "trivy fs --format sarif --output reports/trivy-report.sarif .",
    "security:critical": "trivy fs --severity HIGH,CRITICAL --exit-code 1 .",
    "security:all": "npm run security:json && npm run security:sarif",
    "security:html": "trivy fs --format template --template @contrib/html.tpl --output reports/trivy-report.html ."
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "is-wsl": "^3.1.1",
    "jsdom": "^29.1.1",
    "lefthook": "^1.13.6",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "projen": "^0.99.68",
    "sass": "^1.99.0",
    "semantic-release": "^24.2.9",
    "storybook": "^10.4.1",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
