{
  "name": "toolkit-next-ts-starter",
  "version": "0.0.0",
  "private": false,
  "description": "Enterprise-ready Next.js + strict TypeScript starter with projen, Biome, release automation, and config-driven multi-client architecture.",
  "keywords": [
    "nextjs",
    "starter",
    "template",
    "enterprise",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "toolkit-next-ts-starter": "scripts/create-starter.mjs"
  },
  "files": [
    ".claude/skills.md",
    ".cursor/skills",
    ".editorconfig",
    ".env.example",
    ".github",
    "lefthook.yml",
    ".projen",
    ".projenrc.js",
    ".releaserc.json",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "biome.json",
    "commitlint.config.cjs",
    "docs",
    "next-env.d.ts",
    "next.config.ts",
    "public",
    "scripts/create-starter.mjs",
    "src",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit --pretty",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "analyze:bundle": "node ./scripts/reportBundleSize.mjs",
    "analyze:bundle:build": "node ./scripts/reportBundleSize.mjs --build",
    "analyze:bundle:ci": "node ./scripts/reportBundleSize.mjs --ci",
    "prepare": "lefthook install",
    "projen": "projen",
    "create:starter": "node ./scripts/create-starter.mjs",
    "prepublishOnly": "npm run validate",
    "lhci": "npx -y @lhci/cli autorun --config=.lighthouserc.js --upload.target=temporary-public-storage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "next": "16.2.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.14",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lefthook": "^1.13.6",
    "lint-staged": "^16.4.0",
    "projen": "^0.99.68",
    "sass": "^1.99.0",
    "semantic-release": "^24.2.9",
    "typescript": "^5",
    "storybook": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "playwright": "^1.60.0",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8"
  }
}
